# RepoLens Environment Variables

# Notion Publishing (Optional)
# Get your token from: https://www.notion.so/my-integrations
# Get your parent page ID from the Notion page URL
NOTION_TOKEN=secret_xxx
NOTION_PARENT_PAGE_ID=xxx

# AI-Enhanced Documentation (Optional)
# Enable AI-powered executive summaries, business domains, architecture analysis, etc.
REPOLENS_AI_ENABLED=true

# AI Provider Configuration
# Defaults to OpenAI-compatible API
REPOLENS_AI_PROVIDER=openai_compatible

# Your AI API endpoint (defaults to OpenAI)
# For OpenAI: https://api.openai.com/v1
# For other providers: https://your-provider.com/v1
REPOLENS_AI_BASE_URL=https://api.openai.com/v1

# Your AI API key
REPOLENS_AI_API_KEY=sk-xxx

# AI Model to use (e.g., gpt-4-turbo-preview, gpt-3.5-turbo, claude-3-opus-20240229)
REPOLENS_AI_MODEL=gpt-4-turbo-preview

# AI Generation Settings
REPOLENS_AI_TEMPERATURE=0.2
REPOLENS_AI_MAX_TOKENS=2500
REPOLENS_AI_TIMEOUT_MS=60000
