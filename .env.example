# RepoLens Environment Variables

# =============================================================================
# Error Tracking & Telemetry (Optional)
# =============================================================================
# Enable anonymous error tracking to help improve RepoLens
# When enabled, errors and basic usage stats are sent to Sentry
# No personal information or code contents are collected
# Default: false (opt-in)
REPOLENS_TELEMETRY_ENABLED=false

# =============================================================================
# Notion Publishing (Optional)
# =============================================================================
# Get your token from: https://www.notion.so/my-integrations
# Get your parent page ID from the Notion page URL
NOTION_TOKEN=secret_xxx
NOTION_PARENT_PAGE_ID=xxx

# =============================================================================
# Confluence Publishing (Optional)
# =============================================================================
# Publish documentation to Atlassian Confluence (Cloud or Server)
#
# Setup Instructions:
# 1. Get API Token: https://id.atlassian.com/manage-profile/security/api-tokens
# 2. Find your Confluence URL (e.g., https://your-company.atlassian.net/wiki)
# 3. Find your Space Key (visible in space settings or URL)
# 4. (Optional) Get Parent Page ID from the page URL where docs should be nested
#
# For Atlassian Cloud:
CONFLUENCE_URL=https://your-company.atlassian.net/wiki
CONFLUENCE_EMAIL=trades@rabitaitrades.com
CONFLUENCE_API_TOKEN=your-api-token-here
CONFLUENCE_SPACE_KEY=DOCS
CONFLUENCE_PARENT_PAGE_ID=123456789
#
# For Confluence Server/Data Center (self-hosted):
# CONFLUENCE_URL=https://confluence.yourcompany.com
# CONFLUENCE_EMAIL=username  (use username instead of email)
# CONFLUENCE_API_TOKEN=personal-access-token
# CONFLUENCE_SPACE_KEY=DOCS
# CONFLUENCE_PARENT_PAGE_ID=123456789

# =============================================================================
# Discord Notifications (Optional)
# =============================================================================
# Send documentation update notifications to Discord
# Get your webhook URL from: Server Settings → Integrations → Webhooks → New Webhook
# Example: https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_TOKEN
#
# SECURITY: Never commit this to version control!
# Add to .gitignore: .env
# For GitHub Actions: Add as repository secret named DISCORD_WEBHOOK_URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/xxx

# =============================================================================
# AI-Enhanced Documentation (Optional)
# =============================================================================
# Enable AI-powered executive summaries, business domains, architecture analysis, etc.
REPOLENS_AI_ENABLED=true

# AI Provider Configuration
# Defaults to OpenAI-compatible API
REPOLENS_AI_PROVIDER=openai_compatible

# Your AI API endpoint (defaults to OpenAI)
# For OpenAI: https://api.openai.com/v1
# For other providers: https://your-provider.com/v1
REPOLENS_AI_BASE_URL=https://api.openai.com/v1

# Your AI API key
REPOLENS_AI_API_KEY=sk-xxx

# AI Model to use (e.g., gpt-4-turbo-preview, gpt-3.5-turbo, claude-3-opus-20240229)
REPOLENS_AI_MODEL=gpt-4-turbo-preview

# AI Generation Settings
REPOLENS_AI_TEMPERATURE=0.2
REPOLENS_AI_MAX_TOKENS=2500
REPOLENS_AI_TIMEOUT_MS=60000
